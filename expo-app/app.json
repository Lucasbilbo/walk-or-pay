{
  "expo": {
    "name": "Walk or Pay",
    "slug": "walk-or-pay",
    "scheme": "walkorpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "requiresFullScreen": true,
      "bundleIdentifier": "com.walkorpay.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Walk or Pay reads your step count to verify your daily challenge.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIDeviceFamily": [1]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.walkorpay.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "Walk or Pay reads your step count to verify your daily challenge.",
          "NSHealthUpdateUsageDescription": "Walk or Pay needs access to your health data."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "68f3fa5e-de7e-4d3c-abb7-9eab0879884c"
      }
    }
  }
}
