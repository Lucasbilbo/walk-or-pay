# === SUPABASE ===
# From: Supabase project settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # NEVER expose to frontend

# === STRIPE ===
# From: Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=           # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=       # whsec_... (from webhook endpoint settings)

# === GOOGLE OAUTH ===
# From: Google Cloud Console → APIs → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === APP ===
# Full URL of the deployed app (used for OAuth redirect_uri)
APP_URL=https://walkOrPay.netlify.app

# === FRONTEND (VITE_ prefix — exposed to browser) ===
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_CLIENT_ID=
VITE_STRIPE_PUBLISHABLE_KEY= # pk_live_... or pk_test_...
